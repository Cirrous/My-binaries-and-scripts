#!/bin/bash

# Base directory for playlist profiles
LIB_DIR="$HOME/.local/etc/import-playlist"
SCRIPT_NAME=$(basename "$0")

show_help() {
  echo "A wrapper for yt-dlp to manage and download Youtube Music playlists."
  echo ""
  echo "Usage:"
  echo "  $SCRIPT_NAME <ProfileName>                       Download using a saved profile"
  echo "  $SCRIPT_NAME <URL> <TargetFolder>                Direct download without saving a profile"
  echo "  $SCRIPT_NAME --add <Name> <URL> <TargetFolder>   Create/overwrite a playlist profile"
  echo "  $SCRIPT_NAME -l, --list                          List all saved profiles"
  echo "  $SCRIPT_NAME -h, --help                          Show this help message"
  echo ""
  echo "Profiles are stored in: $LIB_DIR"
  exit 0
}

list_profiles() {
  echo "Saved playlist profiles:"
  echo "------------------------"

  if [ -d "$LIB_DIR" ] && [ "$(ls -A "$LIB_DIR")" ]; then
    for file in "$LIB_DIR"/*; do
      if [ -f "$file" ]; then
        source "$file"
        printf "  %-15s -> %s\n" "$(basename "$file")" "$FOLDER"
      fi
    done
  else
    echo "  No profiles found yet. Create one using --add."
  fi
  exit 0
}

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
  show_help
fi

if [ "$1" = "-l" ] || [ "$1" = "--list" ]; then
  list_profiles
fi

mkdir -p "$LIB_DIR"

if [ "$1" = "--add" ]; then
  if [ -z "$2" ] || [ -z "$3" ] || [ -z "$4" ]; then
    echo "Error: Incomplete arguments for creating a profile."
    echo "Usage (to add profile): $SCRIPT_NAME --add <Name> <URL> <TargetFolder>"
    exit 1
  fi

  NAME="$2"
  URL="$3"
  FOLDER="$4"
  PROFILE_FILE="$LIB_DIR/$NAME"

  echo "URL=\"$URL\"" >"$PROFILE_FILE"
  echo "FOLDER=\"$FOLDER\"" >>"$PROFILE_FILE"

  echo "Success: Profile '$NAME' has been created!"
  echo "Saved at: $PROFILE_FILE"
  exit 0
fi

if [ -z "$1" ]; then
  echo "Error: No profile name or URL provided!"
  echo "Usage (with profile):   $SCRIPT_NAME <ProfileName>"
  echo "Usage (direct):         $SCRIPT_NAME <URL> <TargetFolder>"
  echo "Usage (to add profile): $SCRIPT_NAME --add <Name> <URL> <TargetFolder>"
  exit 1
fi

if [ -f "$LIB_DIR/$1" ]; then
  source "$LIB_DIR/$1"
  echo "Profile '$1' loaded..."
else
  if [ -z "$2" ]; then
    echo "Error: Profile '$1' does not exist and no target folder was specified for a direct download."
    echo "Use '$SCRIPT_NAME --help' for usage instructions."
    exit 1
  fi
  URL="$1"
  FOLDER="$2"
fi

mkdir -p "$FOLDER"

echo "Starting download to: $FOLDER"
yt-dlp -f bestaudio --extract-audio --audio-format mp3 --audio-quality 0 --yes-playlist --download-archive "$FOLDER/.downloaded_songs.txt" -P "$FOLDER" -o '%(title)s.%(ext)s' "$URL"
